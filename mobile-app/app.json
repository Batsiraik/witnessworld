{
  "expo": {
    "name": "Witness World Connect",
    "slug": "witnessworld",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.witnessworldconnect.app",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification"
        ]
      }
    },
    "android": {
      "package": "com.witnessworldconnect.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Witness World Connect to access your photos to set a profile picture.",
          "cameraPermission": "Allow Witness World Connect to use the camera for your profile picture."
        }
      ],
      "expo-sharing",
      [
        "expo-notifications",
        {
          "icon": "./assets/logo.jpg",
          "color": "#1faaf2",
          "defaultChannel": "default",
          "sounds": []
        }
      ],
      "expo-image",
      "expo-av"
    ],
    "extra": {
      "eas": {
        "projectId": "72d60af4-52cf-4180-874f-ff6aae3a890b"
      }
    }
  }
}
