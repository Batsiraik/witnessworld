# Disable security filters for API (Hostinger LiteSpeed / ModSecurity).
<IfModule mod_security.c>
  SecFilterEngine Off
  SecFilterScanPOST Off
</IfModule>
<IfModule mod_security2.c>
  SecRuleEngine Off
</IfModule>
<IfModule LiteSpeed>
  SecRuleEngine Off
  RewriteRule .* - [E=noabort:1]
</IfModule>

# Satisfy any — prevent IP/auth blocks from denying API access.
<IfModule mod_authz_core.c>
  Require all granted
</IfModule>
<IfModule !mod_authz_core.c>
  Order Allow,Deny
  Allow from all
  Satisfy Any
</IfModule>

# CORS + allow all methods for mobile app.
<IfModule mod_headers.c>
  Header always set Access-Control-Allow-Origin "*"
  Header always set Access-Control-Allow-Methods "GET, POST, OPTIONS"
  Header always set Access-Control-Allow-Headers "Authorization, X-Auth-Token, Content-Type, Accept"
</IfModule>

# Pass Authorization to PHP (hosting often strips it; breaks Bearer tokens).
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteRule ^ - [R=200,L]
  RewriteCond %{HTTP:Authorization} .
  RewriteRule ^ - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]
</IfModule>
